# Fill these from your rollup launch output or published registry entry.
# Source of truth after publish:
# - chain ID / EVM chain ID / RPC / REST / JSON-RPC / indexer: mainnets/<your-rollup>/chain.json
# - native denom / symbol / decimals: mainnets/<your-rollup>/assetlist.json
# For MiniEVM rollups using INIT gas, the native denom is typically `evm/<token-address>`, not `uinit`.
NEXT_PUBLIC_ROLLUP_CHAIN_ID=
NEXT_PUBLIC_ROLLUP_CHAIN_NAME=initia-raid-club
NEXT_PUBLIC_ROLLUP_PRETTY_NAME=Initia Raid Club
NEXT_PUBLIC_ROLLUP_EVM_CHAIN_ID=
NEXT_PUBLIC_ROLLUP_RPC_URL=
NEXT_PUBLIC_ROLLUP_REST_URL=
NEXT_PUBLIC_ROLLUP_JSON_RPC_URL=
NEXT_PUBLIC_ROLLUP_INDEXER_URL=
NEXT_PUBLIC_ROLLUP_NATIVE_DENOM=
NEXT_PUBLIC_ROLLUP_NATIVE_SYMBOL=
NEXT_PUBLIC_ROLLUP_NATIVE_DECIMALS=18
# Set after deploying `contracts/raidclub-evm/src/RaidClub.sol`.
NEXT_PUBLIC_RAIDCLUB_CONTRACT=
# Official Initia L1 mainnet bridge source values from initia-registry.
NEXT_PUBLIC_BRIDGE_SRC_CHAIN_ID=interwoven-1
NEXT_PUBLIC_BRIDGE_SRC_DENOM=uinit
NEXT_PUBLIC_ROLLUP_EXPLORER_URL=
NEXT_PUBLIC_INTERWOVEN_APP_NAME=Initia Raid Club
NEXT_PUBLIC_INTERWOVEN_PROJECT_ID=replace-me
